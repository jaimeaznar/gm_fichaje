# Copia a .env y rellena. NUNCA subir .env con valores reales al repo.

# Conexión a Postgres (asyncpg). Local docker-compose por defecto:
DATABASE_URL=postgresql+asyncpg://fichajes:localdev@localhost:5432/fichajes

# Secreto para firmar los JWT (genera uno largo y aleatorio en producción).
JWT_SECRET=change-me-in-production
JWT_EXPIRES_MIN=30

# Residencia de datos (REQ-23): debe ser una región de la UE.
# El arranque y el deploy FALLAN si esto no es una región UE.
DEPLOY_REGION=eu-west-1
SUPABASE_REGION=eu-central-1
